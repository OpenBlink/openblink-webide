{
  "name": "openblink-webide",
  "private": true,
  "version": "0.3.5",
  "description": "OpenBlink WebIDE - browser-based Ruby development for OpenBlink devices",
  "license": "BSD-3-Clause",
  "scripts": {
    "lint": "eslint public_html/js public_html/lib public_html/boards scripts",
    "lint:html": "htmlhint \"public_html/**/*.html\"",
    "lint:json": "node scripts/validate-json.js",
    "lint:static": "node scripts/validate-static-assets.js",
    "check-version": "node scripts/check-version.js",
    "build:codemirror": "node esbuild.config.mjs",
    "dev:codemirror": "node esbuild.config.mjs --watch"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "htmlhint": "^1.1.0"
  },
  "dependencies": {
    "codemirror": "5.65.21",
    "esbuild": "^0.24.0",
    "esbuild-css-modules-plugin": "^2.1.0"
  }
}
